generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id                    String    @id @default(uuid())
  razao_social          String
  cnpj                  String    @unique
  regime                String    @default("Simples Nacional – Anexo I")
  setor                 String?
  responsavel           String?
  email                 String?
  telefone              String?
  banco_principal       String?
  limite_alerta_imposto Decimal   @default(5.5)
  ativo                 Boolean   @default(true)
  created_at            DateTime  @default(now())

  compras          Compra[]
  notas_fiscais    NotaFiscal[]
  documentos_sped  DocumentoSped[]
  banco_lancamentos BancoLancamento[]
  despesas         Despesa[]
  divergencias     Divergencia[]
  thresholds         Threshold?
  contas_bancarias   ContaBancaria[]
  periodos_fechados  PeriodoFechado[]
  usuario_clientes UsuarioCliente[]
  notas_servico        NotaServico[]
  fornecedores_cadastro FornecedorCadastro[]
  contas_pagar          ContaPagar[]

  @@map("clientes")
}

model UsuarioCliente {
  usuario_id String
  cliente_id String
  papel      String  @default("contador")

  cliente Cliente @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@id([usuario_id, cliente_id])
  @@map("usuario_clientes")
}

model Compra {
  id               String   @id @default(uuid())
  cliente_id       String
  periodo          String
  data             DateTime @db.Date
  fornecedor       String
  cnpj_fornecedor  String?
  categoria        String?
  valor            Decimal
  nf_entrada       String?
  cfop             String?
  devolucao        Boolean  @default(false)
  pagamento        String?
  cancelada        Boolean  @default(false)
  created_at       DateTime @default(now())

  cliente     Cliente       @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  divergencia Divergencia[]

  @@map("compras")
}

model NotaFiscal {
  id                  String    @id @default(uuid())
  cliente_id          String
  periodo             String
  data                DateTime  @db.Date
  numero              String
  chave_acesso        String?   @unique
  cliente_nf          String?
  cfop                String?
  valor               Decimal
  recebimento         String?
  data_recebimento    DateTime? @db.Date
  conciliada          Boolean   @default(false)
  cancelada           Boolean   @default(false)
  banco_lancamento_id String?
  created_at          DateTime  @default(now())

  cliente          Cliente           @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  banco_lancamento BancoLancamento[] @relation("NotaConciliada")
  divergencia      Divergencia[]

  @@map("notas_fiscais")
}

// Documentos fiscais lidos de arquivos SPED EFD ICMS/IPI (registros C100/C170/C190)
// Guarda o documento já classificado por CFOP (ver @/lib/cfop) — fonte separada
// de `compras`/`notas_fiscais`, que continuam alimentadas por XML/lançamento manual.
model DocumentoSped {
  id                 String    @id @default(uuid())
  cliente_id         String
  periodo            String        // YYYY-MM
  tipo               String        // 'entrada' | 'saida'
  emissao            String        // 'propria' | 'terceiros'
  cod_participante   String?
  participante_nome  String?
  cnpj_participante  String?
  modelo             String?
  serie              String?
  numero             String
  chave_nfe          String?
  data_emissao       DateTime  @db.Date
  data_entrada_saida DateTime? @db.Date
  valor_total        Decimal
  cfop               String
  classificacao      String        // tipo da classificação CFOP (venda, compra, remessa, ...)
  cancelado          Boolean   @default(false)
  created_at         DateTime  @default(now())

  cliente Cliente @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@map("documentos_sped")
}

model BancoLancamento {
  id             String   @id @default(uuid())
  cliente_id     String
  periodo        String
  data           DateTime @db.Date
  descricao      String
  categoria      String?
  tipo           String   // entrada | saida
  valor          Decimal
  nf_vinculada     String?
  nota_fiscal_id   String?
  status           String   @default("pendente") // ok | pendente | sem_nf | parcial
  conta            String?
  comprovante_url  String?  // URL do comprovante no Supabase Storage
  observacao_parcial String? // Justificativa para conciliação parcial
  created_at       DateTime @default(now())

  cliente      Cliente     @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  nota_fiscal   NotaFiscal?  @relation("NotaConciliada", fields: [nota_fiscal_id], references: [id])
  nota_servico  NotaServico? @relation("NfServicoConciliada")
  divergencia   Divergencia[]
  contas_pagar  ContaPagar[]

  @@map("banco_lancamentos")
}

model Despesa {
  id         String   @id @default(uuid())
  cliente_id String
  periodo    String
  data       DateTime @db.Date
  descricao  String
  categoria  String?
  valor      Decimal
  documento       String?
  comprovante_url String?   // URL do arquivo no Supabase Storage
  conta_banco     String?   // conta bancária de origem (ex: "Itaú", "Caixa Econômica")
  pago_banco Boolean  @default(true)
  dedutivel  String   @default("sim") // sim | parcial | nao
  created_at DateTime @default(now())

  cliente     Cliente       @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  divergencia Divergencia[]

  @@map("despesas")
}

model Divergencia {
  id                  String   @id @default(uuid())
  cliente_id          String
  periodo             String
  tipo                String   // receita_nao_declarada | compra_sem_nf | despesa_sem_comprovante
  severidade          String   // alto | medio | baixo
  valor               Decimal?
  descricao           String?
  banco_lancamento_id String?
  nota_fiscal_id      String?
  compra_id           String?
  despesa_id          String?
  resolvida           Boolean  @default(false)
  observacao          String?
  resolucao_tipo      String?  // nf_emitida | vincular_nf | nao_tributavel | nf_a_receber | solicitar_nf | despesa_sem_nf | nf_recebida | classificar_despesa | transferencia | comprovante_enviado | nao_dedutivel | aguardando
  resolucao_nf_id     String?  // NF vinculada manualmente via resolução
  created_at          DateTime @default(now())

  cliente          Cliente          @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  banco_lancamento BancoLancamento? @relation(fields: [banco_lancamento_id], references: [id])
  nota_fiscal      NotaFiscal?      @relation(fields: [nota_fiscal_id], references: [id])
  compra           Compra?          @relation(fields: [compra_id], references: [id])
  despesa          Despesa?         @relation(fields: [despesa_id], references: [id])

  @@map("divergencias")
}

model ContaBancaria {
  id         String   @id @default(uuid())
  cliente_id String
  nome       String   // "Itaú CC 12345-6"
  banco      String   // "Itaú", "Bradesco", etc.
  tipo       String   @default("corrente") // corrente | poupança | pagamento
  agencia    String?
  numero     String?
  principal         Boolean   @default(false)
  ativo             Boolean   @default(true)
  saldo_inicial     Decimal?  @db.Decimal(15, 2)
  saldo_inicial_data DateTime?
  created_at        DateTime  @default(now())

  cliente Cliente @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@map("contas_bancarias")
}

model PeriodoFechado {
  id          String   @id @default(uuid())
  cliente_id  String
  periodo     String   // "YYYY-MM"
  fechado_por String   // usuario_id
  fechado_em  DateTime @default(now())

  cliente Cliente @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@unique([cliente_id, periodo])
  @@map("periodos_fechados")
}

model NotaServico {
  id                  String   @id @default(uuid())
  cliente_id          String
  periodo             String   // "YYYY-MM"
  numero              String
  data                DateTime @db.Date
  prestador           String
  cnpj_prestador      String?
  discriminacao       String?
  codigo_servico      String?
  valor               Decimal
  status              String   @default("pendente") // pendente | conciliada
  banco_lancamento_id String?  @unique
  created_at          DateTime @default(now())

  cliente          Cliente          @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  banco_lancamento BancoLancamento? @relation("NfServicoConciliada", fields: [banco_lancamento_id], references: [id])

  @@map("notas_servico")
}

model Threshold {
  cliente_id            String  @id
  divergencia_banco_nf  Decimal @default(500)
  compra_sem_nf         Decimal @default(200)
  despesa_sem_doc       Decimal @default(300)
  sublimite_simples_pct Decimal @default(80)

  cliente Cliente @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@map("thresholds")
}

model FornecedorCadastro {
  id         String    @id @default(uuid())
  cliente_id String
  cnpj       String?
  codigo_erp String?
  nome       String
  created_at DateTime  @default(now())

  cliente Cliente @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@map("fornecedores_cadastro")
}

model ContaPagar {
  id                  String    @id @default(uuid())
  cliente_id          String
  fornecedor_codigo   String?
  fornecedor_nome     String
  documento           String
  emissao             DateTime? @db.Date
  entrada             DateTime? @db.Date
  vencimento          DateTime? @db.Date
  valor_parcela       Decimal   @db.Decimal(15, 2)
  valor_pago          Decimal   @default(0) @db.Decimal(15, 2)
  saldo               Decimal   @db.Decimal(15, 2)
  situacao            String    @default("Aberta")
  banco_lancamento_id String?
  created_at          DateTime  @default(now())

  cliente          Cliente          @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  banco_lancamento BancoLancamento? @relation(fields: [banco_lancamento_id], references: [id])

  @@map("contas_pagar")
}
